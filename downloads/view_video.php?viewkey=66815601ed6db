    function getUrlParam(name, url) {
        if(url === 'undefined') {
            url = window.location.href
        }
        name = name.replace(/[\[\]]/g, '\\$&');
        var regex = new RegExp('[?&]' + name + '(=([^&#]*)|&|#|$)'),
