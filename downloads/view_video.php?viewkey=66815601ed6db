                delightElement.addEventListener('play', function(e){
                    PlayerWidgetCommonMethods.setVcServerUrl(vcServerUrl);
                    PlayerWidgetCommonMethods.pingVCS;
                });
            }
        }

        return {
            setVrFormat: setVrFormat,
            pingVcsHandler: pingVcsHandler
        };
    })();

